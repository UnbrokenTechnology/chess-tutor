# Rust build artifacts (release/debug binaries, profiling profile,
# magic-bitboard tables, etc.)
target/

# The Stockfish 11 source archive — its contents are already
# extracted under `reference/Stockfish-sf_11/`, so committing the
# zip too would just bloat the history.
Stockfish-sf_11.zip

# Build artifacts from compiling the reference Stockfish 11 source
# (we only run this locally for apples-to-apples NPS comparisons).
reference/Stockfish-sf_11/src/*.o
reference/Stockfish-sf_11/src/syzygy/*.o
reference/Stockfish-sf_11/src/.depend
reference/Stockfish-sf_11/src/stockfish
reference/Stockfish-sf_11/src/stockfish.exe

# lichess-puzzler reference is a *nested git clone* (AGPL-3.0, used only
# locally for the tactic-library port — same "reference, never shipped"
# posture as the Stockfish source). It carries its own .git, so it can't
# be committed cleanly as files; keep it out of this repo's index.
# Re-clone from github.com/ornicar/lichess-puzzler if missing.
reference/lichess-puzzler/

# dhat heap-profile output (generated when running the CLI with the
# `dhat-heap` feature; useful for one-off allocation audits, but not
# something we want in history).
dhat-heap.json
dhat-stderr.log
dhat-summary.txt

# Scratch search output occasionally written during perf investigation.
search-output.txt

# Local Claude Code settings (per-machine permissions, hooks); the
# committed CLAUDE.md is the project-wide guidance and lives at the
# repo root.
.claude/settings.local.json
# Transient per-run lock for scheduled tasks — runtime state, not source.
.claude/scheduled_tasks.lock

# OS / editor
.DS_Store
Thumbs.db
*.swp
*.swo
