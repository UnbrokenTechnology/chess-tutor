# Rust build artifacts (release/debug binaries, profiling profile,
# magic-bitboard tables, etc.)
target/

# The entire `reference/` tree is LOCAL-ONLY, never committed. It holds
# third-party source used only for the port — all trivially re-downloadable,
# so there's no reason to carry it (or the add/remove diffs) in our history.
# This is the same "reference, never shipped" posture that always applied to
# lichess-puzzler, now applied to the whole directory. Re-create locally:
#   unzip Stockfish-sf_11.zip -d reference/            # Stockfish 11 (GPLv3)
#   git clone https://github.com/ornicar/lichess-puzzler \
#       reference/lichess-puzzler                      # lichess-puzzler (AGPL-3.0)
Stockfish-sf_11.zip
reference/

# dhat heap-profile output (generated when running the CLI with the
# `dhat-heap` feature; useful for one-off allocation audits, but not
# something we want in history).
dhat-heap.json
dhat-stderr.log
dhat-summary.txt

# Scratch search output occasionally written during perf investigation.
search-output.txt

# Local Claude Code settings (per-machine permissions, hooks); the
# committed CLAUDE.md is the project-wide guidance and lives at the
# repo root.
.claude/settings.local.json
# Transient per-run lock for scheduled tasks — runtime state, not source.
.claude/scheduled_tasks.lock

# OS / editor
.DS_Store
Thumbs.db
*.swp
*.swo
